{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MediaPull",
  "version": "1.0.0",
  "identifier": "com.gautamcoder.mediapull",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "MediaPull",
        "width": 1080,
        "height": 720,
        "minWidth": 1000,
        "minHeight": 600,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "bin/*"
    ]
  }
}
